# =============================================================================
# TicketFlow — variabili d'ambiente di esempio
# Copia questo file in ".env" e personalizza i valori.
#   cp .env.example .env
# NON committare mai il file .env reale.
# =============================================================================

# ---- Segreti applicativi ----------------------------------------------------
JWT_SECRET=change-me-with-a-long-random-string
JWT_EXPIRES_IN=2h

# ---- Registry & tagging immagini -------------------------------------------
REGISTRY=localhost:5000
TAG=1.0
REGISTRY_PORT=5000

# ---- Porte pubblicate sull'host --------------------------------------------
FRONTEND_PORT=8080
GATEWAY_PORT=8000
PORTAINER_PORT=9000
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---- Frontend ---------------------------------------------------------------
VITE_API_BASE_URL=/api

# ---- RabbitMQ ---------------------------------------------------------------
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_EXCHANGE=ticketflow.events
RABBITMQ_QUEUE=notifications.order-created

# ---- Database service-auth (PostgreSQL) ------------------------------------
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass
AUTH_DB_NAME=auth_db

# ---- Database service-events (PostgreSQL) ----------------------------------
EVENTS_DB_USER=events_user
EVENTS_DB_PASSWORD=events_pass
EVENTS_DB_NAME=events_db

# ---- Database service-orders (PostgreSQL) ----------------------------------
ORDERS_DB_USER=orders_user
ORDERS_DB_PASSWORD=orders_pass
ORDERS_DB_NAME=orders_db

# ---- Database service-notifications (MongoDB) ------------------------------
NOTIF_DB_NAME=notifications_db

# ---- Logging ----------------------------------------------------------------
LOG_LEVEL=info
